generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "pricing"]
}

enum CardCondition {
  NM
  LP
  MP
  HP
  DMG

  @@schema("public")
}

enum CardLanguage {
  PT_BR
  EN
  JA
  UNKNOWN

  @@schema("public")
}

enum PriceSource {
  MANUAL
  POKEMON_TCG_API
  TCGDEX
  LIGAPOKEMON
  MYPCARDS
  CONVERTED_INTERNATIONAL

  @@schema("public")
}

enum DeckFormat {
  STANDARD
  CASUAL

  @@schema("public")
}

enum DeckGenerationMode {
  OWNED_ONLY
  ALLOW_MISSING

  @@schema("public")
}

enum DeckCardSource {
  OWNED
  MISSING

  @@schema("public")
}

enum CollectionOfferStatus {
  PENDING
  ACCEPTED
  REJECTED

  @@schema("public")
}

enum PriceProvider {
  LIGAPOKEMON
  MYPCARDS

  @@schema("pricing")
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String?
  passwordHash String
  identities   UserIdentity[]
  refreshTokens RefreshToken[]
  collection   CollectionItem[]
  folders      CollectionFolder[]
  folderPermissions CollectionFolderPermission[]
  collectionBids CollectionItemBid[]
  collectionOffers CollectionCartOffer[]
  notifications    Notification[]
  decks        Deck[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@schema("public")
}

model UserIdentity {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@schema("public")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model Card {
  id           String           @id @default(cuid())
  externalId   String           @unique
  provider     String
  name         String
  normalizedName String
  number       String
  printedTotal Int?
  setTotal     Int?
  setId        String?
  setCode      String?
  setName      String?
  rarity       String?
  artist       String?
  releaseDate  String?
  nationalPokedexNumbers Int[] @default([])
  supertype    String?
  subtypes     String[]         @default([])
  types        String[]         @default([])
  regulationMark String?
  rules        String[]         @default([])
  abilities    Json?
  attacks      Json?
  retreatCost  String[]         @default([])
  convertedRetreatCost Int?
  variants     String[]         @default([])
  language     CardLanguage     @default(UNKNOWN)
  imageSmall   String?
  imageLarge   String?
  raw          Json?
  prices       PriceSnapshot[]
  collection   CollectionItem[]
  deckCards    DeckCard[]
  archetypeCards DeckArchetypeCard[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([normalizedName])
  @@index([number])
  @@index([printedTotal])
  @@index([setId])
  @@index([setCode])
  @@schema("public")
}

model CollectionItem {
  id             String        @id @default(cuid())
  userId         String
  cardId         String
  quantity       Int           @default(1)
  condition      CardCondition @default(NM)
  variant        String        @default("normal")
  foil           Boolean       @default(false)
  language       CardLanguage  @default(UNKNOWN)
  notes          String?
  cardPriceId    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  card           Card          @relation(fields: [cardId], references: [id], onDelete: Cascade)
  price          CardPrice?    @relation(fields: [cardPriceId], references: [id], onDelete: SetNull)
  folders        CollectionFolderItem[]

  @@index([userId])
  @@index([cardId])
  @@index([cardPriceId])
  @@unique([userId, cardId, condition, variant, foil, language])
  @@schema("public")
}

model CollectionFolder {
  id        String                 @id @default(cuid())
  userId    String
  name      String
  isPublic  Boolean                @default(false)
  isStore   Boolean                @default(false)
  shareToken String?               @unique
  viewCount Int                    @default(0)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CollectionFolderItem[]
  cartOffers CollectionCartOffer[]
  views      CollectionView[]
  permissions CollectionFolderPermission[]

  @@index([userId])
  @@index([shareToken])
  @@index([viewCount(sort: Desc)])
  @@unique([userId, name])
  @@schema("public")
}

model CollectionFolderPermission {
  id        String           @id @default(cuid())
  folderId  String
  userId    String
  createdAt DateTime         @default(now())
  folder    CollectionFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([folderId, userId])
  @@index([userId])
  @@schema("public")
}

model CollectionView {
  id        String           @id @default(cuid())
  folderId  String
  viewerId  String?
  ip        String?
  userAgent String?
  viewedAt  DateTime         @default(now())
  folder    CollectionFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId, viewedAt])
  @@index([ip, folderId, viewedAt])
  @@schema("public")
}

model CollectionFolderItem {
  id               String           @id @default(cuid())
  folderId         String
  collectionItemId String
  manualPriceBrl   Decimal?         @db.Decimal(10, 2)
  isSold           Boolean          @default(false)
  soldPriceBrl     Decimal?         @db.Decimal(10, 2)
  soldQuantity     Int              @default(0)
  soldAt           DateTime?
  soldToUserId     String?
  createdAt        DateTime         @default(now())
  folder           CollectionFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  collectionItem   CollectionItem   @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  bids             CollectionItemBid[]
  cartOfferItems   CollectionCartOfferItem[]

  @@index([collectionItemId])
  @@index([soldToUserId])
  @@unique([folderId, collectionItemId])
  @@schema("public")
}

model CollectionItemBid {
  id           String               @id @default(cuid())
  folderItemId String
  bidderId     String
  amountBrl    Decimal              @db.Decimal(10, 2)
  quantity     Int                  @default(1)
  createdAt    DateTime             @default(now())
  folderItem   CollectionFolderItem @relation(fields: [folderItemId], references: [id], onDelete: Cascade)
  bidder       User                 @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@index([folderItemId, createdAt])
  @@index([bidderId])
  @@schema("public")
}

model CollectionCartOffer {
  id          String                    @id @default(cuid())
  folderId    String
  buyerId     String
  status      CollectionOfferStatus     @default(PENDING)
  message     String?
  totalOfferBrl Decimal                 @db.Decimal(10, 2)
  decidedAt   DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  folder      CollectionFolder          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  buyer       User                      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items       CollectionCartOfferItem[]

  @@index([folderId, status])
  @@index([buyerId])
  @@schema("public")
}

model CollectionCartOfferItem {
  id           String               @id @default(cuid())
  offerId      String
  folderItemId String
  quantity     Int                  @default(1)
  amountBrl    Decimal              @db.Decimal(10, 2)
  offer        CollectionCartOffer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  folderItem   CollectionFolderItem @relation(fields: [folderItemId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([folderItemId])
  @@schema("public")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@schema("public")
}

model Deck {
  id               String               @id @default(cuid())
  userId           String
  name             String
  format           DeckFormat           @default(STANDARD)
  generationMode   DeckGenerationMode   @default(OWNED_ONLY)
  archetypeId      String?
  validationStatus String               @default("unchecked")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  archetype        DeckArchetype?       @relation(fields: [archetypeId], references: [id], onDelete: SetNull)
  cards            DeckCard[]
  validations      DeckValidationResult[]

  @@index([userId])
  @@index([archetypeId])
  @@schema("public")
}

model DeckCard {
  id        String         @id @default(cuid())
  deckId    String
  cardId    String
  quantity  Int
  source    DeckCardSource @default(OWNED)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deck      Deck           @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card      Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([deckId, cardId, source])
  @@index([cardId])
  @@schema("public")
}

model DeckValidationResult {
  id         String   @id @default(cuid())
  deckId     String
  isValid    Boolean
  totalCards Int
  issues     Json
  createdAt  DateTime @default(now())
  deck       Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, createdAt])
  @@schema("public")
}

model DeckArchetype {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  format      DeckFormat          @default(STANDARD)
  strategy    String?
  source      String              @default("curated")
  sourceUrl   String?
  confidence  Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  cards       DeckArchetypeCard[]
  decks       Deck[]

  @@index([format])
  @@index([source])
  @@schema("public")
}

model DeckArchetypeCard {
  id          String        @id @default(cuid())
  archetypeId String
  cardId      String?
  cardName    String
  quantity    Int
  role        String
  required    Boolean       @default(false)
  priority    Int           @default(0)
  archetype   DeckArchetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  card        Card?         @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([archetypeId])
  @@index([cardId])
  @@index([cardName])
  @@schema("public")
}

model MetagameSyncJob {
  id              String    @id @default(cuid())
  source          String
  status          String
  message         String?
  totalArchetypes Int       @default(0)
  createdAt       DateTime  @default(now())
  finishedAt      DateTime?

  @@index([source, createdAt])
  @@index([status])
  @@schema("public")
}

model PriceSnapshot {
  id         String      @id @default(cuid())
  cardId     String
  source     PriceSource
  currency   String
  amount     Decimal?    @db.Decimal(10, 2)
  label      String
  isFallback Boolean     @default(false)
  capturedAt DateTime    @default(now())
  card       Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, source, capturedAt])
  @@schema("public")
}

model CardPrice {
  id              String             @id @default(cuid())
  number          String
  printedTotal    Int
  name            String?
  setCode         String?
  setName         String?
  provider        PriceProvider
  amountBrl       Decimal            @db.Decimal(10, 2)
  label           String
  sourceUrl       String?
  firstSeenAt     DateTime           @default(now())
  lastCheckedAt   DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  history         CardPriceHistory[]
  collectionItems CollectionItem[]

  @@unique([setCode, number, printedTotal, provider])
  @@index([setCode, number, printedTotal])
  @@index([number, printedTotal])
  @@index([provider])
  @@index([setCode])
  @@schema("pricing")
}

model CardPriceHistory {
  id                String    @id @default(cuid())
  cardPriceId       String
  previousAmountBrl Decimal   @db.Decimal(10, 2)
  newAmountBrl      Decimal   @db.Decimal(10, 2)
  changedAt         DateTime  @default(now())
  cardPrice         CardPrice @relation(fields: [cardPriceId], references: [id], onDelete: Cascade)

  @@index([cardPriceId, changedAt])
  @@schema("pricing")
}

model LigaSyncJob {
  id                String               @id @default(cuid())
  status            String
  delayMs           Int
  totalEditions     Int                  @default(0)
  completedEditions Int                  @default(0)
  currentEdition    String?
  message           String?
  editions          LigaSyncJobEdition[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  finishedAt        DateTime?

  @@index([status, createdAt])
  @@schema("pricing")
}

model LigaSyncJobEdition {
  id            String      @id @default(cuid())
  jobId         String
  edid          String
  code          String
  name          String
  year          Int?
  status        String
  cardsFound    Int         @default(0)
  pricesUpdated Int         @default(0)
  message       String?
  startedAt     DateTime?
  finishedAt    DateTime?
  job           LigaSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@index([code])
  @@schema("pricing")
}

model LigaEditionCache {
  id          String   @id @default(cuid())
  edid        String
  code        String
  name        String
  year        Int?
  searchUrl   String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([edid, code])
  @@index([year])
  @@index([code])
  @@schema("pricing")
}
