{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "pnpm --filter @poke-organizer/shared build && prisma generate && prisma db push --accept-data-loss && nest start --watch",
    "deploy:migrate": "prisma migrate deploy",
    "start": "node dist/main.js",
    "lint": "pnpm --filter @poke-organizer/shared build && tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm --filter @poke-organizer/shared build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma": "prisma"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@poke-organizer/shared": "workspace:*",
    "@prisma/client": "^6.2.1",
    "@supabase/supabase-js": "^2.45.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^5.6.2",
    "nodemailer": "^8.0.10",
    "randomstring": "^1.3.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/randomstring": "^1.3.0",
    "prisma": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
