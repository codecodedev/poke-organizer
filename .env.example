NODE_ENV=development

# API
API_PORT=3333
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3333
WEB_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
POKEMON_TCG_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=https://api.openai.com/v1
ENABLE_BRAZILIAN_PRICE_PROVIDERS=false
PRICING_SERVICE_URL=http://pricing-service:3344

# Database
POSTGRES_USER=poke
POSTGRES_PASSWORD=poke
POSTGRES_DB=poke_organizer
DATABASE_URL=postgresql://poke:poke@postgres:5432/poke_organizer?schema=public
PRICING_DATABASE_URL=postgresql://poke:poke@postgres:5432/poke_organizer?schema=pricing

# Web
VITE_API_URL=http://localhost:3333

# Production notes
# WEB_ORIGIN accepts a comma-separated list when needed, e.g.
# WEB_ORIGIN=https://poke-organizer.vercel.app,https://preview-url.vercel.app
# For local pricing-service against production Postgres, use the production external URL:
# PRICING_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?schema=pricing&sslmode=require
