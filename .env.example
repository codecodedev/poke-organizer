# ==============================================================================
# Poke Organizer - Environment Variables Template
# ==============================================================================
# Copie este arquivo para .env e preencha os valores de acordo com seu ambiente.

NODE_ENV=development

# ------------------------------------------------------------------------------
# API CONFIGURATION
# ------------------------------------------------------------------------------
API_PORT=3333
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3333

# Origem permitida para o CORS (pode ser uma lista separada por vírgula em produção)
WEB_ORIGIN=http://localhost:5173
FRONT_URL=http://localhost:5173

# Autenticação JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ------------------------------------------------------------------------------
# EXTERNAL APIS & AI
# ------------------------------------------------------------------------------

# Pokemon TCG API (https://pokemontcg.io/)
POKEMON_TCG_API_KEY=

# AI Provider para sugestão de Decks (openai | gemini)
DECK_AI_PROVIDER=gemini

# Configurações OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Configurações Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=poke
POSTGRES_PASSWORD=poke
POSTGRES_DB=poke_organizer

# URL de conexão (Prisma)
# Public schema: dados principais da aplicação
DATABASE_URL=postgresql://poke:poke@localhost:5432/poke_organizer?schema=public

# Pricing schema: cache de preços (utilizado pelo pricing-service)
PRICING_DATABASE_URL=postgresql://poke:poke@localhost:5432/poke_organizer?schema=pricing

# ------------------------------------------------------------------------------
# STORAGE & MEDIA
# ------------------------------------------------------------------------------

# Provedor de Storage (local | supabase)
STORAGE_PROVIDER=local

# Configurações Supabase (obrigatório se STORAGE_PROVIDER=supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ------------------------------------------------------------------------------
# EMAIL (RESEND HTTP API)
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here
SMTP_FROM=Coleciona Cards <contato@seudominio.com>

# ------------------------------------------------------------------------------
# PRICING SERVICE (SCRAPER)
# ------------------------------------------------------------------------------
PRICING_SERVICE_URL=http://localhost:3344
PRICING_SERVICE_HOST=0.0.0.0
PRICING_SERVICE_PORT=3344

# Ativar provedores brasileiros (LigaPokemon, MyPCards)
ENABLE_BRAZILIAN_PRICE_PROVIDERS=false

# LigaPokemon Sync (Playwright/Browser configuration)
LIGA_SYNC_HEADLESS=true
LIGA_SYNC_EXECUTABLE_PATH=
LIGA_SYNC_BROWSER_CHANNEL=chrome
LIGA_SYNC_USER_DATA_DIR=./.liga-browser-profile
LIGA_SYNC_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# Para usar um navegador já rodando via CDP
LIGA_SYNC_CDP_URL=
LIGA_SYNC_CDP_URL_FILE=

# ------------------------------------------------------------------------------
# WEB (FRONTEND)
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:3333
VITE_ENABLE_HEAVY_HOLO_EFFECT=true

##logn com google
VITE_GOOGLE_CLIENT_ID=sdad
GOOGLE_CLIENT_ID=asdasda